{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Your homelab Prometheus datasource",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "title": "ResumeLoop",
  "uid": "resumeloop-main",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "App Health",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "title": "Status",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 3, "x": 0, "y": 1 },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "type": "value", "options": { "1": { "text": "UP", "color": "green" } } }],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "targets": [{ "expr": "resumeloop_up", "legendFormat": "status", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }]
    },
    {
      "id": 3,
      "title": "Uptime",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 3, "y": 1 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [{ "expr": "resumeloop_uptime_seconds", "legendFormat": "uptime", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }]
    },
    {
      "id": 4,
      "title": "Heap Used",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 8, "x": 7, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "fillOpacity": 10 } } },
      "targets": [
        { "expr": "resumeloop_nodejs_heap_used_bytes",  "legendFormat": "heap used",  "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } },
        { "expr": "resumeloop_nodejs_heap_total_bytes", "legendFormat": "heap total", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } },
        { "expr": "resumeloop_nodejs_rss_bytes",        "legendFormat": "RSS",        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }
      ]
    },
    {
      "id": 5,
      "title": "DB Size",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 5 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [{ "expr": "resumeloop_db_size_bytes", "legendFormat": "db size", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }]
    },
    {
      "id": 10,
      "title": "Users",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 8 }
    },
    {
      "id": 11,
      "title": "Real Users",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 9 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "resumeloop_users_total{type=\"real\"}", "legendFormat": "users", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }]
    },
    {
      "id": 12,
      "title": "Demo Users (active / total)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 5, "x": 4, "y": 9 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "resumeloop_demo_users_active",        "legendFormat": "active",  "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } },
        { "expr": "resumeloop_users_total{type=\"demo\"}","legendFormat": "all-time","datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }
      ]
    },
    {
      "id": 13,
      "title": "Demo Activity (24h)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 15, "x": 9, "y": 9 },
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 10 } } },
      "targets": [
        { "expr": "resumeloop_demo_users_active",        "legendFormat": "active demos",   "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } },
        { "expr": "resumeloop_users_total{type=\"demo\"}","legendFormat": "total demo ever","datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }
      ]
    },
    {
      "id": 20,
      "title": "Pipeline",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 }
    },
    {
      "id": 21,
      "title": "Jobs by Stage",
      "type": "bargauge",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 10, "x": 0, "y": 17 },
      "options": { "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "resumeloop_jobs_by_stage", "legendFormat": "{{stage}}", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }]
    },
    {
      "id": 22,
      "title": "Resumes Generated",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 10, "y": 17 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "resumeloop_outputs_total", "legendFormat": "total", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }]
    },
    {
      "id": 23,
      "title": "Generation Success Rate",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 14, "y": 17 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.8 }, { "color": "green", "value": 0.95 }] }
        }
      },
      "targets": [{ "expr": "resumeloop_outputs_with_docx_total / resumeloop_outputs_total", "legendFormat": "success rate", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }]
    },
    {
      "id": 24,
      "title": "Visa Kill Rate",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 18, "y": 17 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.1 }, { "color": "red", "value": 0.3 }] }
        }
      },
      "targets": [{ "expr": "resumeloop_jobs_visa_killed_total / resumeloop_jobs_total", "legendFormat": "visa kill rate", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }]
    },
    {
      "id": 30,
      "title": "AI Spend",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 }
    },
    {
      "id": 31,
      "title": "Total Tokens (all-time)",
      "type": "bargauge",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 27 },
      "options": { "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "sum by (provider, direction) (resumeloop_ai_tokens_total)", "legendFormat": "{{provider}} {{direction}}", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }
      ]
    },
    {
      "id": 32,
      "title": "Tokens Last 24h",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 27 },
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 10 } } },
      "targets": [
        { "expr": "sum by (provider) (resumeloop_ai_tokens_24h{direction=\"input\"})",  "legendFormat": "{{provider}} input",  "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } },
        { "expr": "sum by (provider) (resumeloop_ai_tokens_24h{direction=\"output\"})", "legendFormat": "{{provider}} output", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }
      ]
    },
    {
      "id": 33,
      "title": "Tokens by Feature (24h)",
      "type": "bargauge",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 35 },
      "options": { "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "sum by (feature) (resumeloop_ai_tokens_24h)", "legendFormat": "{{feature}}", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }
      ]
    }
  ]
}
