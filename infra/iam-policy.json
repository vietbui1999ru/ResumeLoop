{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "SSMParameters",
      "Effect": "Allow",
      "Action": ["ssm:GetParameter", "ssm:GetParameters"],
      "Resource": "arn:aws:ssm:us-east-1:<ACCOUNT_ID>:parameter/resumeanalyze/prod/*"
    },
    {
      "Sid": "S3Outputs",
      "Effect": "Allow",
      "Action": ["s3:PutObject", "s3:GetObject"],
      "Resource": "arn:aws:s3:::resumeanalyze-outputs/*"
    }
  ]
}
